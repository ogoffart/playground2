import { Theme } from "theme.slint";
import { Icon, IconButton, TagDot, ProgressBar } from "widgets.slint";
import { AppData, Logic } from "globals.slint";
import { DetailRow } from "structs.slint";

component StripePlaceholder inherits Rectangle {
    background: Theme.stripe;
}

component DetButton {
    in property <string> label;
    in property <string> icon;
    in property <bool> primary;
    callback clicked;
    height: 32px;
    horizontal-stretch: 1;
    Rectangle {
        border-radius: 8px;
        background: root.primary
            ? (ta.has-hover ? Theme.accent.brighter(0.07) : Theme.accent)
            : (ta.has-hover ? Theme.hover : Theme.content-bg);
        border-width: root.primary ? 0 : 1px;
        border-color: Theme.border;
        HorizontalLayout {
            alignment: center;
            spacing: 6px;
            Icon { name: root.icon; size: 15px; color: root.primary ? Theme.accent-fg : Theme.text; }
            Text {
                text: root.label;
                vertical-alignment: center;
                font-size: 12.5px;
                font-weight: 550;
                color: root.primary ? Theme.accent-fg : Theme.text;
            }
        }
    }
    ta := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}

export component DetailsPanel inherits Rectangle {
    background: Theme.panel-bg;
    clip: true;
    Rectangle { width: 1px; x: 0; background: Theme.border; }

    Flickable {
        viewport-width: self.width;
        if AppData.detail-mode != 0 : VerticalLayout {
            padding: 18px;
            padding-top: 20px;
            spacing: 0px;

            // preview card
            Rectangle {
                height: 156px;
                border-radius: 11px;
                background: Theme.content-bg;
                border-width: 1px;
                border-color: Theme.border;
                clip: true;
                if AppData.det-is-media : StripePlaceholder { width: 100%; height: 100%; }
                Icon {
                    name: AppData.det-icon;
                    size: AppData.det-is-media ? 46px : 56px;
                    color: Theme.accent;
                }
            }
            Rectangle { height: 16px; }

            Text {
                text: AppData.det-name;
                font-size: 15px;
                font-weight: 650;
                wrap: word-wrap;
                color: Theme.text;
            }
            Rectangle { height: 3px; }
            Text {
                text: AppData.det-kind;
                font-size: 12px;
                color: Theme.text-3;
            }
            Rectangle { height: 16px; }

            // tags (single mode only)
            if AppData.detail-mode == 1 && AppData.det-tags.length > 0 : HorizontalLayout {
                spacing: 6px;
                alignment: start;
                for t in AppData.det-tags : Rectangle {
                    height: 22px;
                    border-radius: 11px;
                    background: Theme.content-bg;
                    border-width: 1px;
                    border-color: Theme.border;
                    HorizontalLayout {
                        padding-left: 7px;
                        padding-right: 9px;
                        spacing: 6px;
                        VerticalLayout { alignment: center; TagDot { color-index: t; d: 9px; } }
                        Text {
                            text: Theme.tag-name(t);
                            vertical-alignment: center;
                            font-size: 11.5px;
                            color: Theme.text-2;
                        }
                    }
                }
            }
            if AppData.detail-mode == 1 && AppData.det-tags.length > 0 : Rectangle { height: 16px; }

            // metadata grid
            Rectangle { height: 1px; background: Theme.border; }
            VerticalLayout {
                padding-top: 14px;
                padding-bottom: 14px;
                spacing: 9px;
                for row in AppData.det-rows : HorizontalLayout {
                    spacing: 14px;
                    Text {
                        text: row.key;
                        font-size: 12px;
                        color: Theme.text-3;
                    }
                    Text {
                        text: row.value;
                        horizontal-stretch: 1;
                        horizontal-alignment: right;
                        font-size: 12px;
                        wrap: word-wrap;
                        color: Theme.text;
                    }
                }
            }

            // actions (single mode only)
            if AppData.detail-mode == 1 : Rectangle { height: 1px; background: Theme.border; }
            if AppData.detail-mode == 1 : Rectangle { height: 14px; }
            if AppData.detail-mode == 1 : HorizontalLayout {
                spacing: 8px;
                DetButton {
                    label: "Open";
                    icon: AppData.det-is-folder ? "folderOpen" : "forward";
                    primary: true;
                    clicked => { Logic.menu-action("open-selected"); }
                }
                DetButton {
                    label: "Share";
                    icon: "share";
                    clicked => { Logic.menu-action("share"); }
                }
            }
        }

        // empty / folder-summary
        if AppData.detail-mode == 0 : VerticalLayout {
            padding: 24px;
            padding-top: 40px;
            spacing: 12px;
            alignment: start;
            HorizontalLayout { alignment: center;
                Icon { name: "info"; size: 34px; sw: 1.3px; color: Theme.text-3; }
            }
            VerticalLayout {
                spacing: 4px;
                Text {
                    text: AppData.det-name;
                    horizontal-alignment: center;
                    font-size: 14px;
                    font-weight: 600;
                    color: Theme.text-2;
                }
                Text {
                    text: AppData.det-kind;
                    horizontal-alignment: center;
                    font-size: 12.5px;
                    color: Theme.text-3;
                }
            }
            Text {
                text: AppData.det-hint;
                horizontal-alignment: center;
                wrap: word-wrap;
                font-size: 12px;
                color: Theme.text-3;
            }
        }
    }
}

export component StatusBar inherits Rectangle {
    height: 28px;
    background: Theme.statusbar;
    Rectangle { height: 1px; y: 0; background: Theme.border; }
    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 14px;
        Text {
            text: AppData.status-left;
            vertical-alignment: center;
            font-size: 11.5px;
            color: Theme.text-3;
        }
        // center transfer chip
        Rectangle {
            horizontal-stretch: 1;
            if AppData.transfer-active : HorizontalLayout {
                alignment: center;
                spacing: 6px;
                Icon { name: "download"; size: 14px; color: Theme.text-2; }
                Text {
                    text: "Downloading… " + round(AppData.transfer-pct * 100) + "%";
                    vertical-alignment: center;
                    font-size: 11.5px;
                    color: Theme.text-2;
                }
                VerticalLayout { alignment: center; ProgressBar { width: 60px; pct: AppData.transfer-pct; } }
                xta := TouchArea { mouse-cursor: pointer; clicked => { AppData.xfer-open = true; } }
            }
        }
        HorizontalLayout {
            spacing: 6px;
            Icon { name: AppData.drive-icon; size: 14px; color: Theme.text-3; }
            Text {
                text: AppData.drive-available;
                vertical-alignment: center;
                font-size: 11.5px;
                color: Theme.text-3;
            }
        }
    }
}

export component TransfersPopover inherits Rectangle {
    width: 320px;
    height: content.preferred-height;
    border-radius: 10px;
    background: Theme.titlebar;
    border-width: 1px;
    border-color: Theme.border-strong;
    drop-shadow-blur: 40px;
    drop-shadow-color: #00000066;
    drop-shadow-offset-y: 18px;

    content := VerticalLayout {
        // header
        Rectangle {
            height: 42px;
            Rectangle { height: 1px; y: parent.height - 1px; background: Theme.border; }
            HorizontalLayout {
                padding-left: 14px;
                padding-right: 10px;
                Text {
                    text: "Transfers";
                    vertical-alignment: center;
                    font-size: 13px;
                    font-weight: 650;
                    color: Theme.text;
                }
                Rectangle { horizontal-stretch: 1; }
                VerticalLayout { alignment: center;
                    IconButton { icon: "close"; icon-size: 14px; btn-w: 24px; btn-h: 24px; clicked => { AppData.xfer-open = false; } }
                }
            }
        }
        // item
        if AppData.transfer-active : HorizontalLayout {
            padding: 14px;
            padding-top: 11px;
            padding-bottom: 11px;
            spacing: 11px;
            Rectangle {
                width: 34px; height: 34px;
                border-radius: 8px;
                background: Theme.accent-soft;
                Icon { name: "video"; size: 18px; color: Theme.accent; }
            }
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 2px;
                Text {
                    text: AppData.transfer-name;
                    font-size: 12.5px;
                    font-weight: 550;
                    overflow: elide;
                    color: Theme.text;
                }
                Text {
                    text: AppData.transfer-stat;
                    font-size: 11px;
                    color: Theme.text-3;
                }
                Rectangle { height: 5px; }
                ProgressBar { pct: AppData.transfer-pct; }
            }
        }
        if !AppData.transfer-active : Text {
            text: "No active transfers";
            height: 44px;
            vertical-alignment: center;
            horizontal-alignment: center;
            font-size: 12.5px;
            color: Theme.text-3;
        }
    }
}
